# ─── Shipman backend env vars ──────────────────────────────────────────────
#
# Two ways to use this file:
#
#  A) Locally — copy to `.env` and `source .env` before `go run` (or use
#     direnv). The .env file is gitignored.
#
#  B) On Render — bulk-push real values via the Render CLI instead of
#     pasting each in the dashboard:
#
#       npm install -g @render-tools/cli       # one-time
#       render login                            # one-time
#       render env push --service-id srv-xxxxx --file .env
#
# Anything marked "(secret)" should never be committed.

# ── Server ─────────────────────────────────────────────────────────────────
HTTP_ADDR=0.0.0.0:8080
APP_URL=https://shipman.demetrijgeras.workers.dev

# ── Database ───────────────────────────────────────────────────────────────
# On Render this is injected from the linked DB; locally point at your
# Postgres (or use individual PG* vars below).
DATABASE_URL=postgres://shipman_db_user:CHANGE_ME@dpg-d86e6keq1p3s73avg090-a.ohio-postgres.render.com/shipman_db?sslmode=require

# Alternatively for local dev:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=demetrigeras
# PGPASSWORD=
# PGDATABASE=shipman
# PGSSLMODE=disable

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_local_dev_only        # (secret) Render auto-generates

# ── AI (DeepSeek via OpenAI-compatible API) ────────────────────────────────
AI_PROVIDER=deepseek
OPENAI_API_KEY=CHANGE_ME                   # (secret) your DeepSeek API key

# ── RocketRamp / Vantack ───────────────────────────────────────────────────
ROCKETRAMP_MERCHANT_ID=CHANGE_ME           # (secret)
ROCKETRAMP_API_KEY=CHANGE_ME               # (secret)
ROCKETRAMP_TEST_MODE=true                  # flip to "false" for production creds
