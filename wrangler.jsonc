{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shipman",
  "main": "worker/index.js",
  "compatibility_date": "2026-05-19",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./Shipman-FE/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
